# Copy this file to .env and fill in real values.

# Secret required in the X-Webhook-Secret header (or similar) for incoming
# ticket webhooks. Falls back to config.json's "webhookSecret" if unset —
# that fallback is a dev-only placeholder, set a real value for anything
# beyond local testing.
WEBHOOK_SECRET=

# Fish Audio API key used for TTS announcements (lib/fish-tts.js).
# Either name works; FISH_API_KEY takes precedence if both are set.
FISH_API_KEY=
FISH_AUDIO_SECRET=

# Set to 1 to run the backend in dev mode (relaxed CORS/logging, etc).
# Leave unset: `npm run dev` and docker-compose.dev.yml set it themselves, and
# docker-compose.yml loads this file into the production container.
DEV=
