{
  "name": "ticket-arena",
  "version": "1.0.0",
  "private": true,
  "description": "FPS-style gamified leaderboard for support tickets",
  "scripts": {
    "start": "node server.js",
    "dev:server": "cross-env DEV=1 node server.js",
    "dev:client": "vite --host 127.0.0.1",
    "dev": "concurrently -k -n server,client -c yellow,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --import tsx --test tests/*.test.js"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.0",
    "vite": "^8.1.4"
  }
}
